# Dependencies
node_modules/
wiki/
reports/

# Local environment & credentials — NEVER commit
.env
.env.*
!.env.example

# Runtime / state — contains DB, WhatsApp linked-device auth, downloaded media
data/

# Voice sidecar — Python venv + Kokoro model (~600MB). Recreated by tools/setup-voice.sh.
tools/voice-env/

# Agent's long-term memory — contains personal info it has learned about you.
# A starter file ships as MEMORY.template.md; setup.sh copies it to MEMORY.md.
MEMORY.md

# Auto-archived conversation transcripts (one .md per compact boundary).
conversations/

# Crash dumps written by the uncaughtException handler.
crashes/

# Marker file written when WhatsApp needs a manual QR re-scan.
data/whatsapp-needs-reauth

# Logs
*.log
logs/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
.~*

# Build artifacts (Bun typecheck doesn't emit, but just in case)
dist/
build/

# Swift menubar app (macapp/) build output — source is committed, artifacts are not
macapp/.build/
macapp/.swiftpm/
*.xcodeproj/xcuserdata/

# Local Claude Code config (machine-specific paths/permissions)
.claude/settings.json
.claude/settings.local.json

# Which agent CLI to drive: "gemini" or "claude". Setup writes this for you.
AGENT_PROVIDER=gemini

# Channels — enable any combination. Setup writes whichever you opt into.

# Telegram
TELEGRAM_BOT_TOKEN=

# Slack (both must be set; uses Socket Mode — no public webhook needed)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# WhatsApp (Baileys, QR scan on first run; auth saved to data/whatsapp-auth/)
# NOTHINGCLAW_WHATSAPP=1

# Voice (Whisper STT for WhatsApp voice notes). Requires `bun run voice install`
# and `bun run voice start` first.
# NOTHINGCLAW_VOICE=1
# WHISPER_URL=http://127.0.0.1:9000
# WHISPER_MODEL=base       # tiny | base | small | medium | large
# KOKORO_URL=http://127.0.0.1:9001
# KOKORO_VOICE=af_heart    # af_heart, af_bella, af_nicole, am_adam, am_michael, bf_emma, bm_george
# KOKORO_FORMAT=ogg        # ogg (voice note) | mp3 (audio attachment) | wav

# Optional overrides
# GEMINI_BIN=gemini
# CLAUDE_BIN=claude
# NOTHINGCLAW_DB=data/nothingclaw.db
# NOTHINGCLAW_WHATSAPP_AUTH=data/whatsapp-auth

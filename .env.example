# .env is for SECRETS and channel-enable flags only.
# Non-secret runtime config (bot name, allowed senders, max sessions, timezone,
# etc.) lives in data/config.json — see README for the schema, or run
# `bun run setup` to generate both files interactively.

# --- Secrets / tokens ---

# Telegram
TELEGRAM_BOT_TOKEN=

# Slack (both must be set; uses Socket Mode — no public webhook needed)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Anthropic (only needed if not using `claude` CLI's OAuth login)
# ANTHROPIC_API_KEY=

# Google OAuth (Gmail, Sheets, etc). Create a "Desktop app" OAuth client at
# https://console.cloud.google.com/apis/credentials then put the IDs here.
# Refresh token is stored in macOS Keychain (service: nothingclaw), not in .env.
# Run `bun run nothingclaw google login` after setting these.
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Channel-enable flags ---

# WhatsApp (Baileys, QR scan on first run; auth saved to data/whatsapp-auth/)
# NOTHINGCLAW_WHATSAPP=1

# --- Optional env overrides (override data/config.json when set) ---

# NOTHINGCLAW_BOT_NAME=Mars
# AGENT_PROVIDER=gemini                       # gemini | claude
# NOTHINGCLAW_WHATSAPP_ALLOWED_JIDS=...       # comma-list, empty = allow all
# NOTHINGCLAW_ALLOWED_PATHS=/Users/...        # comma-list, default = cwd
# NOTHINGCLAW_MAX_SESSIONS=20
# NOTHINGCLAW_CLAUDE_IDLE_MS=900000
# NOTHINGCLAW_TIMEZONE=UTC
# NOTHINGCLAW_VOICE=1
# NOTHINGCLAW_TOOL_PERMISSIONS=bypass         # one-release escape hatch
# LOG_LEVEL=info                              # debug | info | warn | error | fatal

# --- Voice sidecar URLs (only if you've customised them) ---

# WHISPER_URL=http://127.0.0.1:9000
# WHISPER_MODEL=base                          # tiny | base | small | medium | large
# KOKORO_URL=http://127.0.0.1:9001
# KOKORO_VOICE=af_heart
# KOKORO_FORMAT=ogg                           # ogg (voice note) | mp3 | wav

# --- Path / binary overrides ---

# GEMINI_BIN=gemini
# CLAUDE_BIN=claude
# NOTHINGCLAW_DB=data/nothingclaw.db
# NOTHINGCLAW_CONFIG=data/config.json
# NOTHINGCLAW_WHATSAPP_AUTH=data/whatsapp-auth
